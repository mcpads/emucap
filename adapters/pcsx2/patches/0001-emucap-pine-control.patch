+void CBreakPoints::RecordBreakpointHit(BreakpointHitKind kind, u32 pc, u32 address, u32 size)
+{
+	constexpr size_t MAX_BREAKPOINT_HITS = 256;
+	BreakpointHit hit;
+	hit.kind = kind;
+	hit.pc = pc;
+	hit.address = address;
+	hit.size = size;
+	for (int index = 0; index < 32; index++)
+		hit.registers[index] = r5900Debug.getRegister(EECAT_GPR, index).lo;
+	hit.registers[32] = r5900Debug.getHI().lo;
+	hit.registers[33] = r5900Debug.getLO().lo;
+	if (breakpointHits_.size() == MAX_BREAKPOINT_HITS)
+	{
+		breakpointHits_.pop_front();
+		droppedBreakpointHits_++;
+	}
+	breakpointHits_.push_back(std::move(hit));
+}
+
+BreakpointHitBatch CBreakPoints::TakeBreakpointHits()
+{
+	BreakpointHitBatch batch;
+	batch.hits.assign(
+		std::make_move_iterator(breakpointHits_.begin()),
+		std::make_move_iterator(breakpointHits_.end()));
+	breakpointHits_.clear();
+	batch.dropped = droppedBreakpointHits_;
+	droppedBreakpointHits_ = 0;
+	return batch;
+}
