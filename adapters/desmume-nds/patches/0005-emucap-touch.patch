+
+struct EmucapTouchOverride {
+	bool active;
+	int frames_remaining; // <0 = hold until changed; >0 = release after this many frames
+	u16 x, y;             // bottom-screen coords (x 0-255, y 0-191)
+	bool touching;        // true = press at (x,y); false = lift
+};
+static EmucapTouchOverride emucapTouch = {};
+
+void NDS_setEmucapTouchOverride(u16 x, u16 y, bool touching, int frames)
+{
+	emucapTouch.x = x;
+	emucapTouch.y = y;
+	emucapTouch.touching = touching;
+	emucapTouch.frames_remaining = frames;
+	// A lift with no timed hold means "stop overriding the touch".
+	emucapTouch.active = touching || (frames > 0);
+}
+
+static void emucapApplyTouchOverride(UserTouch& t)
+{
+	if (!emucapTouch.active)
+		return;
+	t.isTouch = emucapTouch.touching;
+	if (emucapTouch.touching)
+	{
+		t.touchX = emucapTouch.x;
+		t.touchY = emucapTouch.y;
+	}
+	if (emucapTouch.frames_remaining > 0)
+	{
+		if (--emucapTouch.frames_remaining == 0)
+			emucapTouch.active = false;
 	}
 }
 
