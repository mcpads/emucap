+// "release" -> lift; else "<hexX>,<hexY>[,<hexframes>]" -> press the bottom screen at (x,y).
+// frames defaults to -1 (hold until changed); >0 auto-lifts after that many processed frames (a tap).
+static void emucap_apply_touch(const uint8_t *args) {
+  if (strncmp((const char *)args, "release", 7) == 0) {
+    NDS_setEmucapTouchOverride(0, 0, false, -1);
+    return;
+  }
+  const uint8_t *p = args;
+  uint32_t x = 0, y = 0;
+  hexToInt(&p, &x);
+  if (*p == ',') {
+    p++;
+    hexToInt(&p, &y);
+  }
+  int frames = -1;
+  if (*p == ',') {
+    p++;
+    uint32_t f = 0;
+    hexToInt(&p, &f);
+    frames = (int)f;
+  }
+  NDS_setEmucapTouchOverride((u16)(x & 0xFFFF), (u16)(y & 0xFFFF), true, frames);
+}
