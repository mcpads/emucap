+/* Decode a hex-encoded byte string (e.g. "2f74...") into out, stopping at the
+ * first non-hex character or NUL. Paths ride the RSP hex-encoded because they can
+ * contain spaces/'/'/'.' which are awkward-to-impossible to send raw in a packet. */
+static void emucap_hex_to_string(const uint8_t *p, std::string &out) {
+  out.clear();
+  while (p[0] && p[1]) {
+    int hi = hex(p[0]);
+    int lo = hex(p[1]);
+    if (hi < 0 || lo < 0) break;
+    out.push_back((char)((hi << 4) | lo));
+    p += 2;
+  }
+}
+
+// Mirror of NDSSystem.cpp's INDEX(): map a 32-bit ARM opcode to its slot in
+// des_arm_instructions_set[4096].
+#define EMUCAP_ARM_INDEX(i) ((((i) >> 16) & 0xFF0) | (((i) >> 4) & 0xF))
+
+/* Disassemble `count` instructions from this stub's CPU bus starting at `addr`.
+ * mode: 0 = ARM (4 bytes/insn), 1 = Thumb (2 bytes/insn), -1 = auto from the CPU's
+ * CPSR T-bit. Emits newline-separated "<addrhex>|<opcodehex>|<text>" rows, then
+ * base64-encodes the whole block so the reply carries no RSP-special bytes (ARM
+ * operand text uses '#', '$', '*'). The bridge base64-decodes and parses the rows. */
+static bool emucap_build_disasm_b64(struct gdb_stub_state *stub, uint32_t addr,
+                                    uint32_t count, int mode, std::string &out) {
+  if (stub->direct_memio == NULL || stub->cpu_ctrl == NULL)
+    return false;
+  bool thumb;
+  if (mode == 0)
+    thumb = false;
+  else if (mode == 1)
+    thumb = true;
+  else {
+    // reg 16 is the CPSR; the T (Thumb) flag is bit 5.
+    uint32_t cpsr = stub->cpu_ctrl->read_reg(stub->cpu_ctrl->data, 16);
+    thumb = ((cpsr >> 5) & 1) != 0;
+  }
+  if (count == 0)
+    count = 1;
+  if (count > 4096)
+    count = 4096; // safety cap so a bad request cannot allocate unbounded
+
+  std::string text;
+  char dasm[256];
+  char line[512];
+  for (uint32_t n = 0; n < count; n++) {
+    dasm[0] = 0;
+    if (thumb) {
+      u16 op = stub->direct_memio->read16(stub->direct_memio->data, addr);
+      des_thumb_instructions_set[(op >> 6) & 1023]((u32)addr, (u32)op, dasm);
+      snprintf(line, sizeof(line), "%x|%04x|%s\n", (unsigned)addr, (unsigned)op, dasm);
+      addr += 2;
+    } else {
+      u32 op = stub->direct_memio->read32(stub->direct_memio->data, addr);
+      des_arm_instructions_set[EMUCAP_ARM_INDEX(op)]((u32)addr, op, dasm);
+      snprintf(line, sizeof(line), "%x|%08x|%s\n", (unsigned)addr, (unsigned)op, dasm);
+      addr += 4;
+    }
+    text.append(line);
+  }
+  emucap_base64_encode((const uint8_t *)text.data(), text.size(), out);
+  return true;
+}
