+// emucap: forced input injected by the GDB stub, applied once per frame during input
+// processing so it survives the frontend clearing raw input via update_keypad(0) each frame.
+struct EmucapInputOverride {
+	bool active;
+	int frames_remaining; // <0 = hold until changed; >0 = release after this many frames
+	u16 mask;             // emucap common 12-bit NDS button mask
+};
+static EmucapInputOverride emucapInput = {};
+
+void NDS_setEmucapInputOverride(u16 mask, int frames)
+{
+	emucapInput.mask = mask & 0x0FFF;
+	emucapInput.frames_remaining = frames;
+	// A zero mask with no timed hold means "release everything".
+	emucapInput.active = (emucapInput.mask != 0) || (frames > 0);
+}
+
+int NDS_getEmucapInputOverrideRemaining()
+{
+	return emucapInput.active ? emucapInput.frames_remaining : 0;
+}
+
+static void emucapApplyInputOverride(UserButtons& b)
+{
+	if (!emucapInput.active)
+		return;
+	const u16 m = emucapInput.mask;
+	if (m & (1 << 0))  b.A = true;
+	if (m & (1 << 1))  b.B = true;
+	if (m & (1 << 2))  b.T = true; // select
+	if (m & (1 << 3))  b.S = true; // start
+	if (m & (1 << 4))  b.R = true; // right
+	if (m & (1 << 5))  b.L = true; // left
+	if (m & (1 << 6))  b.U = true; // up
+	if (m & (1 << 7))  b.D = true; // down
+	if (m & (1 << 8))  b.E = true; // R shoulder
+	if (m & (1 << 9))  b.W = true; // L shoulder
+	if (m & (1 << 10)) b.X = true;
+	if (m & (1 << 11)) b.Y = true;
+	if (emucapInput.frames_remaining > 0)
+	{
+		if (--emucapInput.frames_remaining == 0)
+			emucapInput.active = false;
+	}
+}
+
+
 void NDS_beginProcessingInput()
 {
 	// start off from the raw input
 	intermediateUserInput = rawUserInput;
 
+	// emucap: fold in any forced input before autofire/antipodal processing runs
+	emucapApplyInputOverride(intermediateUserInput.buttons);
+
 	// processing is valid now
 	validToProcessInput = true;
 }
