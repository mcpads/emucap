+/* ------------------------------------------------------------------------- *
+ * emucap custom RSP commands: qEmucap,ss (screenshot) + QEmucap,input:<mask> *
+ *                                                                            *
+ * These extend the stub with capture surface the standard GDB-RSP verbs      *
+ * (m/M/g/c/s/Z...) cannot serve. Standard verbs are untouched; only the      *
+ * otherwise-unhandled 'q'/'Q' prefixes gain emucap cases.                    *
+ * ------------------------------------------------------------------------- */
+
+static const char emucap_b64_chars[] =
+  "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
+
+static void emucap_base64_encode(const uint8_t *in, size_t len, std::string &out) {
+  out.clear();
+  out.reserve(((len + 2) / 3) * 4);
+  size_t i = 0;
+  while (i + 3 <= len) {
+    uint32_t n = (in[i] << 16) | (in[i + 1] << 8) | in[i + 2];
+    out.push_back(emucap_b64_chars[(n >> 18) & 0x3f]);
+    out.push_back(emucap_b64_chars[(n >> 12) & 0x3f]);
+    out.push_back(emucap_b64_chars[(n >> 6) & 0x3f]);
+    out.push_back(emucap_b64_chars[n & 0x3f]);
+    i += 3;
+  }
+  if (len - i == 1) {
+    uint32_t n = in[i] << 16;
+    out.push_back(emucap_b64_chars[(n >> 18) & 0x3f]);
+    out.push_back(emucap_b64_chars[(n >> 12) & 0x3f]);
+    out.push_back('=');
+    out.push_back('=');
+  } else if (len - i == 2) {
+    uint32_t n = (in[i] << 16) | (in[i + 1] << 8);
+    out.push_back(emucap_b64_chars[(n >> 18) & 0x3f]);
+    out.push_back(emucap_b64_chars[(n >> 12) & 0x3f]);
+    out.push_back(emucap_b64_chars[(n >> 6) & 0x3f]);
+    out.push_back('=');
+  }
+}
+
+static void emucap_png_put_u32(std::vector<uint8_t> &v, uint32_t x) {
+  v.push_back((x >> 24) & 0xff);
+  v.push_back((x >> 16) & 0xff);
+  v.push_back((x >> 8) & 0xff);
+  v.push_back(x & 0xff);
+}
+
+static void emucap_png_chunk(std::vector<uint8_t> &out, const char type[4],
+                             const uint8_t *data, size_t len) {
+  emucap_png_put_u32(out, (uint32_t)len);
+  size_t crc_start = out.size();
+  out.insert(out.end(), type, type + 4);
+  if (len) out.insert(out.end(), data, data + len);
+  uLong crc = crc32(0L, Z_NULL, 0);
+  crc = crc32(crc, out.data() + crc_start, (uInt)(4 + len));
+  emucap_png_put_u32(out, (uint32_t)crc);
+}
+
+/* Encode 8-bit RGB pixels (row-major, no padding) as a PNG. Returns false on
+ * a zlib failure. */
+static bool emucap_encode_png_rgb(const uint8_t *rgb, uint32_t width,
+                                  uint32_t height, std::vector<uint8_t> &png) {
+  // Raw scanlines: one filter byte (0 = none) per row, then width*3 RGB bytes.
+  std::vector<uint8_t> raw;
+  raw.reserve((size_t)height * (1 + (size_t)width * 3));
+  for (uint32_t y = 0; y < height; y++) {
+    raw.push_back(0);
+    const uint8_t *row = rgb + (size_t)y * width * 3;
+    raw.insert(raw.end(), row, row + (size_t)width * 3);
+  }
+
+  uLongf comp_cap = compressBound((uLong)raw.size());
+  std::vector<uint8_t> comp(comp_cap);
+  uLongf comp_len = comp_cap;
+  if (compress2(comp.data(), &comp_len, raw.data(), (uLong)raw.size(),
+                Z_DEFAULT_COMPRESSION) != Z_OK) {
+    return false;
+  }
+  comp.resize(comp_len);
+
+  static const uint8_t sig[8] = {0x89, 'P', 'N', 'G', 0x0d, 0x0a, 0x1a, 0x0a};
+  png.clear();
+  png.insert(png.end(), sig, sig + 8);
+
+  uint8_t ihdr[13];
+  ihdr[0] = (width >> 24) & 0xff; ihdr[1] = (width >> 16) & 0xff;
+  ihdr[2] = (width >> 8) & 0xff;  ihdr[3] = width & 0xff;
+  ihdr[4] = (height >> 24) & 0xff; ihdr[5] = (height >> 16) & 0xff;
+  ihdr[6] = (height >> 8) & 0xff;  ihdr[7] = height & 0xff;
+  ihdr[8] = 8;   // bit depth
+  ihdr[9] = 2;   // color type: truecolor RGB
+  ihdr[10] = 0;  // compression
+  ihdr[11] = 0;  // filter
+  ihdr[12] = 0;  // interlace
+  emucap_png_chunk(png, "IHDR", ihdr, sizeof(ihdr));
+  emucap_png_chunk(png, "IDAT", comp.data(), comp.size());
+  emucap_png_chunk(png, "IEND", NULL, 0);
+  return true;
+}
+
+/* Read both DS screens from the GPU native buffer (RGB555, top over bottom,
+ * 256x384) and produce a base64-encoded PNG. Returns false if the frame buffer
+ * or encode is unavailable; the caller then replies with an empty (error) packet. */
+static bool emucap_build_screenshot_b64(std::string &out) {
+  if (GPU == NULL) return false;
+  const NDSDisplayInfo &di = GPU->GetDisplayInfo();
+  const u16 *src = di.masterNativeBuffer16;
+  if (src == NULL) return false;
+
+  const uint32_t w = GPU_FRAMEBUFFER_NATIVE_WIDTH;        // 256
+  const uint32_t h = GPU_FRAMEBUFFER_NATIVE_HEIGHT * 2;   // 384 (both screens)
+  const size_t pixels = (size_t)w * h;
+
+  std::vector<uint8_t> rgb(pixels * 3);
+  for (size_t i = 0; i < pixels; i++) {
+    // Native pixel masks are R=0x001F G=0x03E0 B=0x7C00 (see cli/main.cpp).
+    u16 px = src[i];
+    uint8_t r5 = px & 0x1f;
+    uint8_t g5 = (px >> 5) & 0x1f;
+    uint8_t b5 = (px >> 10) & 0x1f;
+    rgb[i * 3 + 0] = (r5 << 3) | (r5 >> 2);
+    rgb[i * 3 + 1] = (g5 << 3) | (g5 >> 2);
+    rgb[i * 3 + 2] = (b5 << 3) | (b5 >> 2);
+  }
+
+  std::vector<uint8_t> png;
+  if (!emucap_encode_png_rgb(rgb.data(), w, h, png)) return false;
+  emucap_base64_encode(png.data(), png.size(), out);
+  return true;
+}
+
+/* Send all bytes of a buffer, looping over short writes (screenshot replies are
+ * far larger than a single send() may flush). Returns -1 on socket error. */
+static int emucap_send_all(SOCKET_TYPE sock, const char *data, size_t len) {
+  size_t sent = 0;
+  while (sent < len) {
+    int n = send(sock, (char *)(data + sent), (int)(len - sent), 0);
+    if (n <= 0) {
+      if (n < 0 && errno == EAGAIN) continue;
+      return -1;
+    }
+    sent += (size_t)n;
+  }
+  return 0;
+}
+
+/* Frame `payload` as $<payload>#<cksum> and send it, retransmitting until the
+ * peer acks with '+'. Mirrors putpacket() but for an arbitrarily large payload
+ * that does not fit the fixed 2 KB stub buffer. */
+static int emucap_putpacket_big(SOCKET_TYPE sock, const std::string &payload) {
+  unsigned char checksum = 0;
+  for (size_t i = 0; i < payload.size(); i++)
+    checksum += (unsigned char)payload[i];
+
+  std::string frame;
+  frame.reserve(payload.size() + 4);
+  frame.push_back('$');
+  frame.append(payload);
+  frame.push_back('#');
+  frame.push_back(hexchars[checksum >> 4]);
+  frame.push_back(hexchars[checksum & 0xf]);
+
+  uint8_t reply_ch;
+  do {
+    if (emucap_send_all(sock, frame.data(), frame.size()) != 0)
+      return -1;
+    int reply_found = 0;
+    do {
+      int read_res = recv(sock, (char *)&reply_ch, 1, 0);
+      if (read_res == 0) {
+        return -1;
+      } else if (read_res == -1) {
+        if (errno != EAGAIN) return -1;
+      } else {
+        reply_found = 1;
+      }
+    } while (!reply_found);
+  } while (reply_ch != '+');
+  return 0;
+}
+
+/* Parse "<hexmask>" or "<hexmask>,<hexframes>" (pointer just past the ':') and
+ * install it as the forced input override. No frames field means hold until the
+ * next input command. */
+static void emucap_apply_input(const uint8_t *args) {
+  const uint8_t *p = args;
+  uint32_t mask = 0;
+  hexToInt(&p, &mask);
+  int frames = -1;
+  if (*p == ',') {
+    p++;
+    uint32_t f = 0;
+    hexToInt(&p, &f);
+    frames = (int)f;
+  }
+  NDS_setEmucapInputOverride((u16)(mask & 0x0fff), frames);
+}
