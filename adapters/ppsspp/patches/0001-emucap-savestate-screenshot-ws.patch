+// Retrieve a screenshot even while the game runs (emucap.screenshot)
+//
+// emucap fork: stock gpu.buffer.screenshot only works when the GPU is already GE-stepping
+// (CORE_STEPPING_GE); no stock WebSocket command enters GE stepping, so a headless capture of
+// a running game fails with "Could not download output". This drives GE stepping itself: it
+// breaks the GPU on the next frame, downloads the output framebuffer via the same code path as
+// gpu.buffer.screenshot (identical reply shape), then resumes.
+//
+// Parameters (same as gpu.buffer.screenshot):
+//  - type: either 'uri' or 'base64' (optional, defaults to 'uri').
+//  - alpha: boolean to include the alpha channel for 'uri' type.
+//  - stackWidth: optional, forced width for 'uri' type (increases height.)
+//
+// Response (same event name): matches gpu.buffer.screenshot.
+void WebSocketGPUBufferEmucapScreenshot(DebuggerRequest &req) {
+	if (!currentDebugMIPS->isAlive())
+		return req.Fail("CPU not started");
+	if (!gpu)
+		return req.Fail("GPU not available");
+
+	// If the GPU is already GE-stepping, capture directly; otherwise drive it.
+	bool weEnteredStepping = false;
+	if (!GPUStepping::IsStepping()) {
+		// Break at the next vsync -> the EmuThread's GE run loop calls GPUStepping::EnterStepping.
+		gpu->SetBreakNext(GPUDebug::BreakNext::VSYNC);
+		weEnteredStepping = true;
+
+		const double timeoutSeconds = 5.0;
+		double start = time_now_d();
+		while (!GPUStepping::IsStepping()) {
+			if (time_now_d() - start > timeoutSeconds) {
+				gpu->ClearBreakNext();
+				return req.Fail("Timed out entering GPU stepping for screenshot");
+			}
+			sleep_ms(1, "ge-screenshot-poll");
+		}
+	}
+
+	// Now GE-stepping: reuse the exact gpu.buffer.screenshot path (guard now passes).
+	GenericStreamBuffer(req, [](const GPUDebugBuffer *&buf, bool *isFramebuffer) {
+		*isFramebuffer = false;
+		return GPUStepping::GPU_GetOutputFramebuffer(buf);
+	});
+
+	// Resume the GPU (and CPU) back to running if we broke it.
+	if (weEnteredStepping)
+		gpu->ClearBreakNext();
+}
