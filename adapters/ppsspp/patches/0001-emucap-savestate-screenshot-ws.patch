+// GNU General Public License 2.0 for more details.
+
+// A copy of the GPL 2.0 should have been included with the program.
+// If not, see http://www.gnu.org/licenses/
+
+// Official git repository and contact information can be found at
+// https://github.com/hrydgard/ppsspp and http://www.ppsspp.org/.
+
+// emucap fork: adds savestate.save / savestate.load WebSocket commands.
+//
+// Stock PPSSPP exposes no WebSocket save-state command. SaveState::Save/Load are
+// asynchronous: they enqueue an operation that is serviced by SaveState::Process(),
+// which the EmuThread only runs while stepping (Core_ProcessStepping) or, in the GUI,
+// once per frame. Headless never pumps Process() while CORE_RUNNING_CPU, so this
+// handler breaks the CPU into stepping (if running), lets the EmuThread service the
+// operation, waits for the completion callback, then restores the prior run state.
+
+#include <chrono>
+#include <condition_variable>
+#include <memory>
+#include <mutex>
+#include <string>
+#include <string_view>
+
+#include "Common/File/Path.h"
+#include "Core/Core.h"
+#include "Core/Debugger/WebSocket/SaveStateSubscriber.h"
+#include "Core/Debugger/WebSocket/WebSocketUtils.h"
+#include "Core/SaveState.h"
+#include "Core/System.h"
+
+DebuggerSubscriber *WebSocketSaveStateInit(DebuggerEventHandlerMap &map) {
+	// No per-connection state, the save state system is global.
+	map["savestate.save"] = &WebSocketSaveStateSave;
+	map["savestate.load"] = &WebSocketSaveStateLoad;
+
+	return nullptr;
+}
+
+namespace {
+
+struct SaveStateWait {
+	std::mutex m;
+	std::condition_variable cv;
+	bool done = false;
+	SaveState::Status status = SaveState::Status::FAILURE;
+	std::string message;
+};
+
+// Runs a save or load synchronously (from the debugger's perspective) and responds.
+void RunSaveStateOperation(DebuggerRequest &req, bool isSave, BreakReason breakReason) {
+	if (PSP_GetBootState() != BootState::Complete)
+		return req.Fail("Game not running");
+
+	std::string path;
+	if (!req.ParamString("path", &path))
+		return;
+
+	auto wait = std::make_shared<SaveStateWait>();
+	SaveState::Callback cb = [wait](SaveState::Status status, std::string_view message, std::string_view metadata) {
+		std::lock_guard<std::mutex> guard(wait->m);
+		wait->status = status;
+		wait->message = std::string(message);
+		wait->done = true;
+		wait->cv.notify_all();
+	};
+
+	// SaveState::Process() only runs on the EmuThread while it is stepping. If the game
+	// is running, break so the operation is serviced, and resume afterward.
+	bool resumeAfter = false;
+	if (coreState == CORE_RUNNING_CPU) {
+		Core_Break(breakReason, 0);
+		resumeAfter = true;
+	}
+
+	const Path filename(path);
+	if (isSave)
+		SaveState::Save(filename, -1, cb);
+	else
+		SaveState::Load(filename, -1, cb);
+
+	bool completed;
+	{
+		std::unique_lock<std::mutex> guard(wait->m);
+		completed = wait->cv.wait_for(guard, std::chrono::seconds(15), [&] { return wait->done; });
+	}
+
+	if (resumeAfter)
+		Core_Resume();
+
+	if (!completed)
+		return req.Fail(isSave ? "Timed out saving state" : "Timed out loading state");
+	if (wait->status == SaveState::Status::FAILURE)
+		return req.Fail(wait->message.empty() ? (isSave ? "Failed to save state" : "Failed to load state") : wait->message);
+
+	JsonWriter &json = req.Respond();
+	json.writeString("path", path);
+	if (!wait->message.empty())
+		json.writeString("message", wait->message);
+}
+
+}  // namespace
+
+// Save emulator state to a file (savestate.save)
+//
+// Parameters:
+//  - path: string host path to write the save state to.
+//
+// Response (same event name):
+//  - path: string, the path written.
+//  - message: optional string status message.
+void WebSocketSaveStateSave(DebuggerRequest &req) {
+	RunSaveStateOperation(req, true, BreakReason::SavestateSave);
+}
+
+// Load emulator state from a file (savestate.load)
+//
+// Parameters:
+//  - path: string host path to read the save state from.
+//
+// Response (same event name):
+//  - path: string, the path read.
+//  - message: optional string status message.
+void WebSocketSaveStateLoad(DebuggerRequest &req) {
+	RunSaveStateOperation(req, false, BreakReason::SavestateLoad);
+}
