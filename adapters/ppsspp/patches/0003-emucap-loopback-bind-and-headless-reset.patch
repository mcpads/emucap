@@ -786,6 +789,63 @@ void PSP_Shutdown(bool success) {
 	IncrementDebugCounter(DebugCounter::GAME_SHUTDOWN);
 }
 
+// emucap headless reset coordination — see Core/System.h. Guards a "reset pending" flag and a
+// monotonic "reset completed" generation, so the debugger's game.reset handler (WS thread) can
+// block until the run loop (emu thread) has actually torn down and rebooted the PSP.
+namespace {
+std::mutex g_headlessResetMutex;
+std::condition_variable g_headlessResetCv;
+bool g_headlessResetMode = false;
+bool g_headlessResetPending = false;
+uint64_t g_headlessResetDoneGen = 0;
+}  // namespace
+
+void Core_EnableHeadlessResetMode() {
+	std::lock_guard<std::mutex> guard(g_headlessResetMutex);
+	g_headlessResetMode = true;
+}
+
+bool Core_HeadlessResetMode() {
+	std::lock_guard<std::mutex> guard(g_headlessResetMutex);
+	return g_headlessResetMode;
+}
+
+void Core_RequestHeadlessReset() {
+	std::lock_guard<std::mutex> guard(g_headlessResetMutex);
+	g_headlessResetPending = true;
+}
+
+bool Core_ConsumeHeadlessReset() {
+	std::lock_guard<std::mutex> guard(g_headlessResetMutex);
+	if (!g_headlessResetPending)
+		return false;
+	g_headlessResetPending = false;
+	return true;
+}
+
+void Core_NotifyHeadlessResetDone() {
+	{
+		std::lock_guard<std::mutex> guard(g_headlessResetMutex);
+		g_headlessResetDoneGen++;
+	}
+	g_headlessResetCv.notify_all();
+}
+
+uint64_t Core_HeadlessResetGeneration() {
+	std::lock_guard<std::mutex> guard(g_headlessResetMutex);
+	return g_headlessResetDoneGen;
+}
+
+bool Core_WaitHeadlessReset(uint64_t sinceGeneration, double timeoutSeconds) {
+	std::unique_lock<std::mutex> guard(g_headlessResetMutex);
+	// Generation-based so a reset that completes between the caller's snapshot and this wait is not
+	// missed (the predicate is already satisfied and returns immediately).
+	return g_headlessResetCv.wait_for(
+		guard,
+		std::chrono::duration<double>(timeoutSeconds),
+		[&] { return g_headlessResetDoneGen > sinceGeneration; });
+}
+
 void PSP_RunLoopWhileState() {
 	// We just run the CPU until we get to vblank. This will quickly sync up pretty nicely.
 	// The actual number of cycles doesn't matter so much here as we will break due to CORE_NEXTFRAME, most of the time hopefully...
