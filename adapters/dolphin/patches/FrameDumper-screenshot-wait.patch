+ScreenshotWaitResult FrameDumper::SaveScreenshotAndWait(std::string filename,
+                                                        std::chrono::milliseconds timeout)
+{
+  {
+    std::lock_guard<std::mutex> lk(m_screenshot_lock);
+    if (m_screenshot_request.IsSet())
+      return ScreenshotWaitResult::Busy;
+    m_screenshot_name = filename;
+    m_screenshot_completed.Reset();
+    m_screenshot_request.Set();
+  }
+
+  if (m_screenshot_completed.WaitFor(timeout))
+    return ScreenshotWaitResult::Completed;
+
+  // If the video thread has not claimed the request, cancel it before returning. If it already
+  // claimed the request, it owns the local filename and may finish encoding, but it cannot affect
+  // a later request.
+  if (m_screenshot_request.TestAndClear())
+  {
+    std::lock_guard<std::mutex> lk(m_screenshot_lock);
+    if (m_screenshot_name == filename)
+      m_screenshot_name.clear();
+  }
+  return ScreenshotWaitResult::TimedOut;
+}
