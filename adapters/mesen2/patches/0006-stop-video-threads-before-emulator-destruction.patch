@@ -81,6 +81,15 @@ Emulator::Emulator()
 
 Emulator::~Emulator()
 {
+	// A signal-driven process exit can bypass the managed Release call.  Stop the emulation and
+	// renderer workers while every Emulator member is still alive; otherwise they can race member
+	// destruction through SoundMixer, VideoDecoder, or EmuSettings.
+	Stop(false, true, false);
+	_gameClient->Disconnect();
+	_gameServer->StopServer();
+	_videoRenderer->StopThread();
+	_videoDecoder->StopThread();
+	_shortcutKeyHandler.reset();
 }
 
 void Emulator::Initialize(bool enableShortcuts)
