{
  "schema": "emucap-feature-contracts/v3",
  "contract_version": 3,
  "default_expectations": [
    "CORE.AVAIL.1",
    "CORE.REJECT.1",
    "CORE.SUCCESS.1",
    "CORE.PARAM.1",
    "CORE.UNIT.1",
    "CORE.EVIDENCE.1",
    "CORE.BOUND.1",
    "CORE.SESSION.1",
    "CORE.CLEANUP.1"
  ],
  "expectations": [
    {
      "id": "CORE.AVAIL.1",
      "category": "invariant",
      "expression": "f in methods => callable(f)"
    },
    {
      "id": "CORE.REJECT.1",
      "category": "invariant",
      "expression": "not P_eff => explicit_error and delta_tool = 0"
    },
    {
      "id": "CORE.SUCCESS.1",
      "category": "invariant",
      "expression": "response.ok => Q_eff and I_f and O_eff"
    },
    {
      "id": "CORE.PARAM.1",
      "category": "invariant",
      "expression": "accepted(parameter) => defined_effect(parameter)"
    },
    {
      "id": "CORE.UNIT.1",
      "category": "invariant",
      "expression": "declared_unit = measured_unit"
    },
    {
      "id": "CORE.EVIDENCE.1",
      "category": "observation",
      "expression": "authority(response) <= authority(evidence)"
    },
    {
      "id": "CORE.BOUND.1",
      "category": "invariant",
      "expression": "work(feature,input) <= declared_bound(feature,input)"
    },
    {
      "id": "CORE.SESSION.1",
      "category": "invariant",
      "expression": "generation(response) = generation(request)"
    },
    {
      "id": "CORE.CLEANUP.1",
      "category": "invariant",
      "expression": "effect_terminal(feature) => released(transient_resources(feature))"
    },
    {
      "id": "TIME.RESPONSE.1",
      "category": "temporal",
      "expression": "G(accepted(q) => F<=D_h response_terminal(q))"
    },
    {
      "id": "TIME.COMPLETE.1",
      "category": "temporal",
      "expression": "G(response_completed(q) => effect_terminal(q))"
    },
    {
      "id": "TIME.EFFECT.1",
      "category": "temporal",
      "expression": "G(armed(q) => F<=B_e effect_terminal(q))"
    },
    {
      "id": "TIME.CLEANUP.1",
      "category": "temporal",
      "expression": "G(effect_terminal(q) => not owns_transient(q) or generation_terminated)"
    },
    {
      "id": "TIME.CANCEL.1",
      "category": "temporal",
      "expression": "G(request_scoped(q) and disconnect(q) => F<=D_h ((aborted(q) and cleanup(q)) or generation_terminated))"
    },
    {
      "id": "TIME.DETACHED.1",
      "category": "temporal",
      "expression": "G(detached(q) => operation_id(q) and cancelable(q) and (observable(q) U effect_terminal(q)))"
    },
    {
      "id": "TIME.GAP.1",
      "category": "temporal",
      "expression": "G(host_gap and composition_open and not adapter_owned => frozen and delta_emulator_time = 0)"
    },
    {
      "id": "TIME.GENERATION.1",
      "category": "temporal",
      "expression": "G(active(q) => same_generation(q) U effect_terminal(q))"
    },
    {
      "id": "TIME.EXACT.1",
      "category": "temporal",
      "expression": "G(completed(advance(unit,n)) => delta_counter(unit) = n)"
    },
    {
      "id": "TIME.PERSISTENT.1",
      "category": "temporal",
      "expression": "G(persistent_owned and status_requested => status_reports_owner) and G(persistent_owned => persistent_owned W (explicit_release or generation_terminated))"
    },
    {
      "id": "LIFE.LEASE.1",
      "category": "temporal",
      "expression": "G(acquire_lease(g,c) => current = g) and G(lease_held(g,c1) and c1 != c2 => not mutation_authorized(g,c2)) and G(holder_exited(g) => F<=D_h lease_available(g))"
    },
    {
      "id": "LIFE.PUBLISH.1",
      "category": "invariant",
      "expression": "publish(g2) => current_before = prepared_predecessor(g2) and unique_current"
    },
    {
      "id": "LIFE.TERMINATE.1",
      "category": "invariant",
      "expression": "terminate(p,g) => owned_by(p,g) and identity_matches_now(p,g) and ((current(g) and lease_held(g)) or (unpublished(g) and prepared_owned(g)))"
    },
    {
      "id": "MEM.READ.EXACT.1",
      "category": "postcondition",
      "expression": "read.ok => len(read.bytes) = request.length and read.space = request.memory_type"
    },
    {
      "id": "MEM.WRITE.APPLY.1",
      "category": "postcondition",
      "expression": "write.ok => Applied(memory_type,address,bytes)"
    },
    {
      "id": "MEM.DUMP.PATH.1",
      "category": "postcondition",
      "expression": "dump.ok => writes_confined_to(request.path) and literal_path(request.path)"
    },
    {
      "id": "STATE.FILTER.1",
      "category": "postcondition",
      "expression": "get_state.ok and groups not empty => returned_groups subset_of groups and groups_applied"
    },
    {
      "id": "VIDEO.CURRENT.1",
      "category": "observation",
      "expression": "screenshot.ok => image.generation = current_generation and image.freshness = current"
    },
    {
      "id": "INPUT.HOLD.RELEASE.1",
      "category": "postcondition",
      "expression": "set_input(empty).ok => override_engaged(after) = false"
    },
    {
      "id": "INPUT.PULSE.SAME_WINDOW.1",
      "category": "postcondition",
      "expression": "press(buttons,n).completed => every button is injected in the same n-frame window"
    },
    {
      "id": "INPUT.PULSE.CLEANUP.1",
      "category": "invariant",
      "expression": "effect_terminal(press) => transient_override_engaged(after) = false"
    },
    {
      "id": "EXEC.PAUSE.HALT.1",
      "category": "postcondition",
      "expression": "pause.ok => frozen(after) and not free_progress(selected_execution_unit)"
    },
    {
      "id": "EXEC.PAUSE.PERSIST.1",
      "category": "temporal",
      "expression": "G(frozen and generation_live and not release_event => X(frozen))"
    },
    {
      "id": "EXEC.STEP.FRAME.1",
      "category": "postcondition",
      "expression": "step(n,unit=frames).completed => delta_frame = n and frozen(after)"
    },
    {
      "id": "EXEC.STEP.INSTR.1",
      "category": "postcondition",
      "expression": "step(n,unit=instructions,cpu).completed => delta_instruction(cpu) = n and frozen(after)"
    },
    {
      "id": "STATE.LOAD.COHERENT.1",
      "category": "postcondition",
      "expression": "load.ok => one_snapshot(cpu_state,device_state) and generation = current_generation"
    },
    {
      "id": "PROBE.ATOMIC.1",
      "category": "invariant",
      "expression": "probe.ok => no_external_mutation_between(load,advance,read)"
    },
    {
      "id": "BP.ARMED.1",
      "category": "postcondition",
      "expression": "set_breakpoint.ok => armed(id,kind,space,range,condition)"
    },
    {
      "id": "BP.CAPABILITY.1",
      "category": "invariant",
      "expression": "set_breakpoint.ok and device_kind(kind) => negotiated(kind)"
    },
    {
      "id": "EVENT.ONCE.1",
      "category": "invariant",
      "expression": "drained(event) => event not_in future_poll_events"
    },
    {
      "id": "EVENT.ATOMIC.1",
      "category": "observation",
      "expression": "emitted(device_event) => one_callback(device_clock,event.snapshot)"
    },
    {
      "id": "TRACE.AUTHORITY.1",
      "category": "observation",
      "expression": "authority(result) = exact => every frame has exact evidence"
    },
    {
      "id": "FAIL.TIMEOUT.NONCRASH.1",
      "category": "invariant",
      "expression": "timeout and not adapter_fatal_evidence => execution != crashed"
    },
    {
      "id": "ANALYSIS.PROVENANCE.1",
      "category": "observation",
      "expression": "analysis.ok => same(content,base_state,input_lineage,contract_generation)"
    }
  ],
  "features": [
    {
      "id": "transport.hello",
      "surface": "wire",
      "methods": ["hello"],
      "temporal_classes": ["T0"],
      "disposition": "retain",
      "expectations": ["CORE.AVAIL.1"]
    },
    {
      "id": "lifecycle.bootstrap",
      "surface": "public",
      "methods": ["bootstrap"],
      "temporal_classes": ["T0"],
      "disposition": "retain",
      "expectations": ["FAIL.TIMEOUT.NONCRASH.1"]
    },
    {
      "id": "lifecycle.launch-plan",
      "surface": "public",
      "methods": ["launch_plan"],
      "temporal_classes": ["T0"],
      "disposition": "retain",
      "expectations": []
    },
    {
      "id": "lifecycle.launch",
      "surface": "public",
      "methods": ["launch"],
      "temporal_classes": ["T3"],
      "disposition": "retain",
      "expectations": [
        "TIME.RESPONSE.1",
        "TIME.GENERATION.1",
        "LIFE.LEASE.1",
        "LIFE.PUBLISH.1",
        "LIFE.TERMINATE.1"
      ]
    },
    {
      "id": "runtime.status",
      "surface": "public",
      "methods": ["status"],
      "temporal_classes": ["T0"],
      "disposition": "retain",
      "expectations": ["FAIL.TIMEOUT.NONCRASH.1"]
    },
    {
      "id": "failure.context",
